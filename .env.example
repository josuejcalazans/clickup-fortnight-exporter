CLICKUP_API_TOKEN=seu_token_aqui
CLICKUP_TEAM_ID=ID_DO_SEU_TIME
PORT=3007
HOURLY_RATE_USD=??

# ===== Invoice (PDF) =====
# 1 = generate PDF invoice, 0 = skip PDF
INVOICE_PDF_ENABLE=1
INVOICE_CODE=in-1000

# invoice dates
INVOICE_ISSUE_DATE_SOURCE=end
INVOICE_DUE_DAYS=13

# provider (seller)
INVOICE_FROM_NAME=
INVOICE_FROM_CNPJ=
INVOICE_FROM_PHONE=+55 00 0000-0000
INVOICE_FROM_EMAIL=you@example.com

# client (buyer)
INVOICE_TO_NAME=SpringBolt, LLC

# service text
INVOICE_SERVICE_TITLE=Software Development
# supports placeholders: {startMonthDayOrdinal}, {endMonthDayOrdinal}, {year}
INVOICE_SERVICE_DESCRIPTION_TEMPLATE=Software Development as per agreement.\nDate of service: {startMonthDayOrdinal} and {endMonthDayOrdinal}, {year}.

# ===== E-mail (Gmail) após export =====
# 1 = envia e-mail com CSV + PDF da invoice (se INVOICE_PDF_ENABLE=1)
EMAIL_ENABLE=0
GMAIL_USER=you@gmail.com
# Senha de app: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx
# Vários destinatários: vírgula ou ponto-e-vírgula
EMAIL_TO=finance@company.com
# Opcional (default = GMAIL_USER)
# EMAIL_FROM=you@gmail.com
# Nome / cargo na linha do email-signature.html (placeholders {{SIGNATURE_*}})
EMAIL_SIGNATURE_DISPLAY_NAME=Your Name
EMAIL_SIGNATURE_JOB_TITLE=Software Engineer
EMAIL_SIGNATURE_HTML_FILE=./email-signature.html
